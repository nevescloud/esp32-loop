# esp32-loop local config — copy to `.env` (gitignored) and fill in.
# `esp32loop wifi <board>` reads these when you omit the ssid/password args, so the
# credential lives in your environment, never in the repo or a board.toml. An MCP
# agent can omit them too — the server reads its own env, keeping the secret out of
# the model's context. An already-exported shell var wins over this file.
ESP32LOOP_WIFI_SSID=
ESP32LOOP_WIFI_PASSWORD=
